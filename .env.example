# Model/API configuration for the AI investment agent system.
# Copy to .env locally and fill in values. Do not commit .env.

# LLM gateway
# The current recommended setup is Viviai / New API, which is OpenAI-compatible.
# Use gpt-5.5 for the weekly research brief and gpt-5.4-mini for fast helper tasks.
LLM_PROVIDER=viviai
LLM_BASE_URL=https://api.viviai.cc/v1
LLM_API_KEY_ENV=OPENAI_API_KEY
LLM_MODEL=gpt-5.5
LLM_FAST_MODEL=gpt-5.4-mini

# LLM providers / compatible aliases
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.viviai.cc/v1
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=

# Video/transcript and web research helpers
BIBI_API_TOKEN=
# TranscriptAPI.com key. Used by the installed `youtube-full` skill.
# This replaces the need for a separate ClawHub `transcriptapi` skill unless you intentionally swap implementations.
TRANSCRIPT_API_KEY=
SCRAPECREATORS_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=
SERPER_API_KEY=
PARALLEL_API_KEY=
LAST30DAYS_PYTHON=

# Market and fundamentals data
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
SEC_EDGAR_USER_AGENT="Your Name your.email@example.com"

# Optional Longbridge setup is normally done via CLI/MCP auth rather than env.
# Recommended: install longbridge-terminal, then run `longbridge auth login`
# with read-only/data permissions for this research workflow.
